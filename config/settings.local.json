{
  "enabledPlugins": {
    "superpowers@superpowers-marketplace": false,
    "claude-code-setup@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "superpowers-marketplace": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers-marketplace"
      }
    },
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    }
  },
  "permissions": {
    "allow": [
      "Bash(npm *)",
      "Bash(node *)",
      "Bash(pnpm *)",
      "Bash(npx *)",
      "Bash(npx playwright *)",
      "Bash(NPM_CONFIG_REGISTRY=https://registry.npmjs.org npx playwright *)",
      "Bash(NPM_CONFIG_REGISTRY=https://registry.npmjs.org playwright install chromium)",
      "Bash(playwright --version)",
      "Bash(python3:*)",
      "Bash(pip3 --version)",
      "Bash(pip3 install *)",
      "Bash(curl *)",
      "Bash(ls *)",
      "Bash(grep *)",
      "Bash(grep -v \"^$\")",
      "Bash(grep -v \"^[[:space:]]*$\")",
      "Bash(open *)",
      "Bash(bash)",
      "Bash(mdls *)",
      "Bash(qlmanage *)",
      "Bash(crontab *)",
      "Bash(crontab -l)",
      "Bash(/usr/bin/python3 *)",
      "Bash(security find-generic-password *)",
      "Bash(brew list *)",
      "Bash(brew install *)",
      "Bash(docker login *)",
      "Bash(docker info *)",
      "Bash(networksetup -getwebproxy Wi-Fi)",
      "Bash(networksetup -getsecurewebproxy Wi-Fi)",
      "Bash(gh repo *)",
      "Bash(claude mcp *)",
      "Bash(claude plugin *)",
      "Bash(claude auth *)",
      "Bash(claude --version)",
      "Read(*)",
      "WebFetch(*)",
      "WebSearch",
      "Skill(skill-creator)",
      "Skill(style-design)",
      "Skill(design-system)",
      "Skill(find-skills)",
      "Skill(interaction-design)",
      "Skill(ui-ux-pro-max)",
      "Skill(ux-research)",
      "Skill(hotel-admin-blue)",
      "Skill(update-config)",
      "mcp__figma-desktop__get_design_context",
      "mcp__figma-desktop__get_screenshot",
      "mcp__figma-desktop__get_metadata",
      "mcp__figma-hosted__*"
    ],
    "defaultMode": "bypassPermissions"
  },
  "disabledMcpjsonServers": [
    "pencil",
    "open-design",
    "stitch"
  ],
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0,
    "refreshInterval": 10
  },
  "autoUpdatesChannel": "stable",
  "skillOverrides": {
    "agent-browser": "user-invocable-only",
    "agent-reach": "user-invocable-only",
    "design-md": "user-invocable-only",
    "emblem-market-research": "user-invocable-only",
    "brainstorming": "user-invocable-only",
    "emil-design-eng": "user-invocable-only",
    "gsap-advanced-animation": "user-invocable-only",
    "design-system": "name-only",
    "figma-create-new-file": "name-only",
    "find-skills": "name-only",
    "hotel-admin-blue": "name-only",
    "information-architecture": "name-only",
    "interaction-design": "name-only",
    "skill-creator": "name-only",
    "test-driven-development": "name-only",
    "update-config": "name-only",
    "using-git-worktrees": "name-only",
    "ux-research": "name-only",
    "web-design-guidelines": "name-only"
  },
  "skipDangerousModePermissionPrompt": true,
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[token-optimizer] 建议运行 /context 查看当前 Token 基线 | [self-improving-agent] 检查 .learnings/ 有无适用于本任务的记录'"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[self-improving-agent] 子代理已完成，检查是否需要记录经验教训到 .learnings/'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/fangcang/.claude/sync-to-github.sh"
          }
        ]
      }
    ]
  }
}