{
  "enabledPlugins": {
    "superpowers@superpowers-marketplace": false,
    "claude-code-setup@claude-plugins-official": false
  },
  "extraKnownMarketplaces": {
    "superpowers-marketplace": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers-marketplace"
      }
    },
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    }
  },
  "permissions": {
    "allow": [
      "Bash(npm *)",
      "Bash(node *)",
      "Bash(pnpm *)",
      "Bash(npx *)",
      "Bash(playwright --version)",
      "Bash(python3:*)",
      "Bash(pip3 --version)",
      "Bash(pip3 install *)",
      "Bash(curl *)",
      "Bash(ls *)",
      "Bash(grep *)",
      "Bash(grep -v \"^$\")",
      "Bash(grep -v \"^[[:space:]]*$\")",
      "Bash(open *)",
      "Bash(bash)",
      "Bash(kill %1)",
      "Bash(xargs kill *)",
      "Bash(wait)",
      "Bash(break)",
      "Bash(chmod +x *)",
      "Bash(mdls *)",
      "Bash(qlmanage *)",
      "Bash(crontab *)",
      "Bash(crontab -l)",
      "Bash(mdfind -name \"Google Chrome\" -onlyin /Applications)",
      "Bash(echo \"---CRON_EXIT:$?---\")",
      "Bash(echo \"exit: $?\")",
      "Bash(cat /Users/fangcang/Library/LaunchAgents/*.plist)",
      "Bash(/usr/bin/python3 *)",
      "Bash(import sys *)",
      "Bash(identify \"/Users/fangcang/.claude/image-cache/d22f9f20-1fc8-4e25-9275-a89609ac95bf/1.png\")",
      "Bash(security find-generic-password *)",
      "Bash(security dump-keychain *)",
      "Bash(sips -s format jpeg /tmp/figma_design.png --out /tmp/figma_design.jpg)",
      "Bash(brew list *)",
      "Bash(brew install *)",
      "Bash(docker login *)",
      "Bash(docker info *)",
      "Bash(nslookup registry-1.docker.io)",
      "Bash(osascript -e 'quit app \"Docker\"')",
      "Bash(networksetup -getwebproxy Wi-Fi)",
      "Bash(networksetup -getsecurewebproxy Wi-Fi)",
      "Bash(gh repo *)",
      "Bash(shortcuts list *)",
      "Bash(claude mcp *)",
      "Bash(claude plugin *)",
      "Bash(claude auth *)",
      "Bash(claude --version)",
      "Bash(xcrun --sdk macosx swiftc -o /tmp/ocr2 -framework Vision -framework CoreImage -framework Foundation /tmp/ocr.swift)",
      "Bash(/tmp/ocr2)",
      "Bash(tesseract --version)",
      "Bash(tesseract /tmp/figma_design.png /tmp/figma_ocr_output -l chi_sim+eng --psm 6)",
      "Bash(tesseract /tmp/figma_design.jpg /tmp/figma_ocr_output -l chi_sim+eng --psm 6)",
      "Bash(tesseract figma_design.png figma_ocr_output -l chi_sim+eng --psm 6)",
      "Bash(tesseract figma_design.png figma_ocr_output2 -l chi_sim+eng --psm 3)",
      "Read(*)",
      "WebFetch(*)",
      "WebSearch",
      "Skill(skill-creator)",
      "Skill(style-design)",
      "Skill(design-system)",
      "Skill(find-skills)",
      "Skill(interaction-design)",
      "Skill(ui-ux-pro-max)",
      "Skill(ux-research)",
      "Skill(hotel-admin-blue)",
      "Skill(update-config)",
      "mcp__figma-desktop__*",
      "mcp__figma-hosted__*"
    ],
    "defaultMode": "bypassPermissions"
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0,
    "refreshInterval": 10
  },
  "autoUpdatesChannel": "stable",
  "skillOverrides": {
    "agent-browser": "user-invocable-only",
    "agent-reach": "user-invocable-only",
    "design-md": "user-invocable-only",
    "emblem-market-research": "user-invocable-only",
    "brainstorming": "user-invocable-only",
    "emil-design-eng": "user-invocable-only",
    "gsap-advanced-animation": "user-invocable-only",
    "ui-ux-pro-max": "user-invocable-only",
    "design-system": "name-only",
    "figma-create-new-file": "name-only",
    "find-skills": "user-invocable-only",
    "hotel-admin-blue": "name-only",
    "information-architecture": "user-invocable-only",
    "interaction-design": "name-only",
    "skill-creator": "name-only",
    "test-driven-development": "name-only",
    "update-config": "user-invocable-only",
    "using-git-worktrees": "user-invocable-only",
    "ux-research": "name-only",
    "web-design-guidelines": "user-invocable-only",
    "dispatching-parallel-agents": "user-invocable-only",
    "executing-plans": "user-invocable-only",
    "subagent-driven-development": "user-invocable-only",
    "systematic-debugging": "name-only",
    "verification-before-completion": "user-invocable-only",
    "writing-plans": "user-invocable-only",
    "style-design": "name-only",
    "frontend-design": "name-only",
    "hue": "user-invocable-only",
    "figma-generate-design": "name-only",
    "figma-code-connect": "name-only",
    "figma-create-design-system-rules": "user-invocable-only",
    "figma-generate-diagram": "name-only",
    "figma-generate-library": "name-only",
    "figma-implement-design": "name-only",
    "figma-use": "name-only",
    "figma-use-figjam": "user-invocable-only",
    "make-interfaces-feel-better": "name-only",
    "canvas-design": "user-invocable-only",
    "bencium-controlled-ux-designer": "name-only"
