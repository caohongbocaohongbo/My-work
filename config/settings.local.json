  "skipDangerousModePermissionPrompt": true,
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[token-optimizer] 建议运行 /context 查看当前 Token 基线 | [self-improving-agent] 检查 .learnings/ 有无适用于本任务的记录'"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/fangcang/.claude/scripts/session-context.sh start"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[self-improving-agent] 子代理已完成，检查是否需要记录经验教训到 .learnings/'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/fangcang/.claude/sync-to-github.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/fangcang/.claude/scripts/session-context.sh end"
          }
        ]
      }
    ]
  }
}