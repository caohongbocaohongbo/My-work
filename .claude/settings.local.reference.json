{
  "_说明": "此文件为 ~/.claude/settings.local.json 的参考模板。换环境时复制到 ~/.claude/settings.local.json",
  "enabledPlugins": {
    "superpowers@superpowers-marketplace": true,
    "claude-code-setup@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "superpowers-marketplace": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers-marketplace"
      }
    },
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    }
  },
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[token-optimizer] 建议运行 /context 查看当前 Token 基线 | [self-improving-agent] 检查 .learnings/ 有无适用于本任务的记录'"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[self-improving-agent] 子代理已完成，检查是否需要记录经验教训到 .learnings/'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/fangcang/.claude/sync-to-github.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0,
    "refreshInterval": 10
  },
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true
}
